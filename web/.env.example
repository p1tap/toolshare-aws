# Leave everything unset (or VITE_API_MODE!=real) for MOCK MODE — the whole
# app runs offline with seeded data and a simulated checkout saga.

# Real mode: values come from the CloudFormation stack outputs.
#VITE_API_MODE=real
#VITE_API_URL=https://xxxxxxxx.execute-api.ap-southeast-1.amazonaws.com/staging
#VITE_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
#VITE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
#VITE_AWS_REGION=ap-southeast-1
# Images default to /images/* on the same origin (CloudFront). Override only
# for local dev against a real stage:
#VITE_IMAGES_BASE=https://dxxxxxxxxxxxx.cloudfront.net/images
